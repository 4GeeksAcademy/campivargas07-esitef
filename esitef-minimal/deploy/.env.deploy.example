# Copiar a .env.deploy (no commitear). Usado por upload-theme.sh

SFTP_HOST=ftp.tu-host.com
SFTP_PORT=22
SFTP_USER=staging_user
SFTP_PASS=
# Ruta remota al wp-content/themes del staging
REMOTE_THEME_PATH=/public_html/staging/wp-content/themes/esitef-minimal

STAGING_URL=https://staging.esitef.com
WP_ADMIN_URL=https://staging.esitef.com/wp-admin

# Solo staging — nunca credenciales live de PayPal aquí
