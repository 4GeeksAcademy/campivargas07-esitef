# Copiar a .env.deploy y completar (NO commitear)
# SiteGround: Site Tools → Devs → SSH Keys Manager → SSH Credentials

SFTP_HOST=CHANGE_ME
# SiteGround SFTP usa puerto 18765 (no 22)
SFTP_PORT=18765
SFTP_USER=CHANGE_ME
# Opcional si usas clave SSH (recomendado SiteGround; password SSH suele estar deshabilitado):
# SSH_KEY_PATH=/Users/TU_USUARIO/.ssh/siteground_esitef
# SFTP_PASSWORD=  # solo si tu cuenta permite password (raro en SiteGround)

# Ruta ABSOLUTA al tema en staging (File Manager → wp-content/themes/esitef-minimal)
# Ejemplo típico SiteGround:
# /home/customer/www/staging3.esitef.com/public_html/online/wp-content/themes/esitef-minimal
REMOTE_THEME_PATH=CHANGE_ME

STAGING_URL=https://staging3.esitef.com/online
WP_ADMIN_URL=https://staging3.esitef.com/online/wp-admin
